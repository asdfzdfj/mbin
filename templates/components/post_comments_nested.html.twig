{% if view is same as theme_setting_constant('CLASSIC') %}
    {% for reply in comment.nested %}
        {{ component('post_comment', {
            comment: reply,
            showNested: false,
            level: 3
        }) }}
    {% endfor %}
{% else %}
    {% for reply in comment.children|sort_author_first(comment) %}
        {{ component('post_comment', {
            comment: reply,
            showNested: true,
            level: level + 1
        }) }}
    {% endfor %}
{% endif %}
