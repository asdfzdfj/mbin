<aside class="options" id="options">
    {% if not theme_setting_is('ENTRY_COMMENTS_VIEW', 'CHAT') %}
    <div></div>
    <menu class="options__main">
        <li>
            <a href="{{ options_url('sortBy', 'top') }}"
               class="{{ html_classes({'active': route_has_param('sortBy', 'top')}) }}">
                {{ 'top'|trans }}
            </a>
        </li>
        <li>
            <a href="{{ options_url('sortBy', 'hot') }}"
               class="{{ html_classes({'active': route_has_param('sortBy', 'hot')}) }}">
                {{ 'hot'|trans }}
            </a>
        </li>
        <li>
            <a href="{{ options_url('sortBy', 'active') }}"
               class="{{ html_classes({'active': route_has_param('sortBy', 'active')}) }}">
                {{ 'active'|trans }}
            </a>
        </li>
        <li>
            <a href="{{ options_url('sortBy', 'newest') }}"
               class="{{ html_classes({'active': route_has_param('sortBy', 'newest')}) }}">
                {{ 'newest'|trans }}
            </a>
        </li>
        <li>
            <a href="{{ options_url('sortBy', 'oldest') }}"
               class="{{ html_classes({'active': route_has_param('sortBy', 'oldest')}) }}">
                {{ 'oldest'|trans }}
            </a>
        </li>
    </menu>
    {% else %}
        <div class="options__title"><h2>{{ 'comments'|trans }} ({{ entry.commentCount }})</h2></div>
    {% endif %}
    <menu class="options__view">
        <li class="dropdown">
            <button aria-label="{{ 'change_view'|trans }}"
                    title="{{ 'change_view'|trans }}"><i
                        class="fa-solid fa-layer-group" aria-hidden="true"></i>
            </button>
            <ul class="dropdown__menu">
                <li>
                    <a class="{{ html_classes({'active': theme_setting_is('ENTRY_COMMENTS_VIEW', 'CLASSIC')}) }}"
                       href="{{ path('theme_settings', {key: theme_setting_constant('ENTRY_COMMENTS_VIEW'), value: theme_setting_constant('CLASSIC')}) }}">{{ 'classic_view'|trans }}</a>
                </li>
                <li>
                    <a class="{{ html_classes({'active': theme_setting_is('ENTRY_COMMENTS_VIEW', 'CHAT')}) }}"
                       href="{{ path('theme_settings', {key: theme_setting_constant('ENTRY_COMMENTS_VIEW'), value: theme_setting_constant('CHAT')}) }}">{{ 'chat_view'|trans }}</a>
                </li>
                <li>
                    <a class="{{ html_classes({'active': theme_setting_is('ENTRY_COMMENTS_VIEW', 'TREE')}) }}"
                       href="{{ path('theme_settings', {key: theme_setting_constant('ENTRY_COMMENTS_VIEW'), value: theme_setting_constant('TREE')}) }}">{{ 'tree_view'|trans }}</a>
                </li>
            </ul>
        </li>
    </menu>
</aside>
