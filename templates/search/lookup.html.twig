{% extends 'base.html.twig' %}

{%- block title -%}
    {{- 'lookup'|trans }} - {{ parent() -}}
{%- endblock -%}

{% block mainClass %}page-lookup page-search page-settings{% endblock %}

{% block header_nav %}
{% endblock %}

{% block sidebar_top %}
{% endblock %}

{% block body %}
    <h1 hidden>{{ 'lookup'|trans }}</h1>
    <div class="section section--top">
        <div class="container">
            <form method="get" action="{{ path('search_lookup') }}">
                <div class="flex" style="align-items: center">
                    <input value="{{ q }}" type="text" name="q" class="form-control"
                           placeholder="{{ 'lookup_placeholder'|trans }}" autofocus>
                    <button class="btn btn__primary" type="submit" title="{{ 'lookup'|trans }}" aria-label="{{ 'lookup'|trans }}">
                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    {{ include('layout/_flash.html.twig') }}

    <div class="alert alert__info">this is a work in progress</div>

    <div id="content" class="{{ html_classes('overview subjects comments-tree comments', {
        'show-comment-avatar': theme_setting_is('KBIN_COMMENTS_SHOW_USER_AVATAR', 'TRUE'),
        'show-post-avatar': theme_setting_is('KBIN_POSTS_SHOW_USERS_AVATARS', 'TRUE')
    }) }}">
        {% if objects|length %}
            {% for object in objects %}
                {% if object.type is defined and object.type is same as 'user' %}
                    <div class="section">
                        {{ component('user_box', {user: object.object}) }}
                    </div>
                {% elseif object.type is defined and object.type is same as 'magazine' %}
                    {{ component('magazine_box', {magazine: object.object, stretchedLink: false}) }}
                {% else %}
                    {{ include('layout/_subject_list.html.twig', {
                        results: [object],
                        entryCommentAttributes: {showMagazineName: true, showEntryTitle: true},
                        postCommentAttributes: {withPost: false}
                    }) }}
                {% endif %}
            {% endfor %}
        {% endif %}
    </div>
{% endblock %}
